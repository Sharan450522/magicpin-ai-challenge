# Copy to `.env` and fill in values. Never commit `.env` or real API keys.
#
# Render: set LLM_API_KEY (and optional BOT_CONTACT_EMAIL) in the dashboard;
#         Render injects PORT automatically — no need to set it here on cloud.

# --- LLM (Groq) ---
LLM_PROVIDER=groq
# Required for LLM path; leave empty to use deterministic templates only
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_SEED=20260426
LLM_TIMEOUT_SECONDS=8

# --- Bot metadata (GET /v1/metadata) — should match what you configure on Render ---
BOT_TEAM_NAME=Sharan Vera Merchant Engine
# Comma-separated or JSON array, e.g. Sharan K or ["Sharan K","Teammate"]
BOT_TEAM_MEMBERS=Sharan K
BOT_MODEL=llama-3.3-70b-versatile
BOT_APPROACH=Hybrid Groq composer with deterministic templates, playbooks, and hydration fallbacks
BOT_CONTACT_EMAIL=your.email@example.com
BOT_VERSION=1.0.0
# ISO-8601 Z; omit to let the server stamp submitted_at at request time
# BOT_SUBMITTED_AT=2026-05-02T12:00:00Z

# --- Local only (optional); Render sets PORT for you ---
# PORT=8080
